<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wetalk.modules.social.mapper.GroupMemberMapper">
    <select id="findMemberIds" resultType="java.lang.String">
        SELECT user_id FROM group_member
        WHERE group_id = #{groupId} AND leaved_at IS NULL
    </select>
</mapper>
