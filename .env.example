# =============================================================================
# WeTalk Chat App — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
# 在 Railway.app 上则通过 Dashboard → Variables 设置
#
# Railway 推荐设置:
#   NODE_ENV=production
#   ADMIN_PASS=<强密码>
#   CORS_ORIGIN=https://your-app.railway.app

# ─── 服务器 ──────────────────────────────────────────────────────
PORT=3000                              # 监听端口 (Railway 自动设置)
NODE_ENV=production                    # 环境: development | production
CORS_ORIGIN=*                          # 允许的跨域来源 (生产环境建议具体域名)

# ─── 管理员后台 ──────────────────────────────────────────────────
ADMIN_USER=admin                       # 管理员用户名
ADMIN_PASS=设置一个强密码              # ⚠️ 生产环境必须修改！默认 admin888 不安全

# ─── Web Push 推送通知 (可选) ────────────────────────────────────
# 首次使用需生成 VAPID 密钥: node tools/generate-vapid-keys.mjs
VAPID_PUBLIC_KEY=                      # VAPID 公钥
VAPID_PRIVATE_KEY=                     # VAPID 私钥
VAPID_SUBJECT=mailto:admin@example.com # 推送联系人邮箱

# ─── 可选配置 ────────────────────────────────────────────────────
# CHAT_SERVER_URL=                     # 桌面端覆盖服务器地址
# LOG_LEVEL=info                       # 日志级别 (预留)
