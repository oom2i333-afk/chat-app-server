{
  "name": "com.chatapp.mobile",
  "version": "1.0.0",
  "description": "Chat App - 移动聊天客户端",
  "main": "index.js",
  "scripts": {
    "build": "node build.js",
    "sync": "npx cap sync",
    "android:open": "npx cap open android",
    "android:build": "npx cap sync && cd android && ./gradlew assembleRelease",
    "ios:open": "npx cap open ios",
    "ios:build": "npx cap sync && cd ios && xcodebuild -workspace App.xcworkspace -scheme App -configuration Release"
  },
  "dependencies": {
    "@capacitor/camera": "^7.0.5",
    "@capacitor/core": "^7.0.0",
    "@capacitor/device": "^7.0.5",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/network": "^7.0.4",
    "@capacitor/push-notifications": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/ios": "^7.0.0"
  }
}
